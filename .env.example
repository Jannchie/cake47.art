# Local admin API token. Use a long random value outside local development.
NUXT_ADMIN_TOKEN=

# Cloudflare Worker name. Optional; defaults to cake47-art.
CLOUDFLARE_WORKER_NAME=cake47-art

# Cloudflare resources used by NuxtHub on Workers.
NUXT_HUB_CLOUDFLARE_DATABASE_ID=
NUXT_HUB_CLOUDFLARE_R2_BUCKET=

# Required for Wrangler deploys and remote D1 migrations.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Required by `pnpm db:migrate:production`.
NUXT_HUB_CLOUDFLARE_ACCOUNT_ID=
NUXT_HUB_CLOUDFLARE_API_TOKEN=
